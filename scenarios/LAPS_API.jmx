        <JSR223Assertion guiclass="TestBeanGUI" testclass="JSR223Assertion" testname="JSR223 Assertion" enabled="false">
          <stringProp name="cacheKey">true</stringProp>
          <stringProp name="filename"></stringProp>
          <stringProp name="parameters"></stringProp>
          <stringProp name="script">import groovy.json.JsonSlurper

def response = prev.getResponseDataAsString()

try {
    def json = new JsonSlurper().parseText(response)

    def errors = []

    if (!json.userId?.toString()?.trim()) {
        errors &lt;&lt; &quot;UserId field is missing or empty&quot;
    }

    if (!json.email?.toString()?.trim()) {
        errors &lt;&lt; &quot;Email field is missing or empty&quot;
    }

    if (errors) {
        AssertionResult.setFailure(true)
        AssertionResult.setFailureMessage(errors.join(&quot; | &quot;))
    }

} catch (Exception e) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Invalid JSON response: &quot; + e.getMessage())
}</stringProp>
          <stringProp name="scriptLanguage">groovy</stringProp>
        </JSR223Assertion>
