 WDS.log.info(&quot;Clicked Continue:--------&quot;)    

    WDS.log.info(&quot;:-----ENDED  HOW IT WORKS PAGE SCRIPT--------&quot;)   
// Allow paint entries to settle a little
Thread.sleep(1500)

// Collect navigation + paint metrics
def metrics = WDS.browser.executeScript(&quot;&quot;&quot;
    var result = {
        load_ms: null,
        dom_content_loaded_ms: null,
        ttfb_ms: null,
        fcp_ms: null,
            paint_count: 0
    };

    var nav = performance.getEntriesByType(&apos;navigation&apos;);
    if (nav &amp;&amp; nav.length &gt; 0) {
        var n = nav[0];
        result.load_ms = n.loadEventEnd;
        result.dom_content_loaded_ms = n.domContentLoadedEventEnd;
        result.ttfb_ms = n.responseStart - n.requestStart;
    } else if (performance.timing) {
        result.load_ms = performance.timing.loadEventEnd - performance.timing.navigationStart;
        result.dom_content_loaded_ms = performance.timing.domContentLoadedEventEnd - performance.timing.navigationStart;
        result.ttfb_ms = performance.timing.responseStart - performance.timing.requestStart;
    }

    var paints = performance.getEntriesByType(&apos;paint&apos;);
    for (var i = 0; i &lt; paints.length; i++) {
        if (paints[i].name === &apos;first-contentful-paint&apos;) {
			   
            result.fcp_ms = paints[i].startTime;
            break;
															  
        }
    }

    return result;
&quot;&quot;&quot;)

// Capture LCP separately
def lcp = WDS.browser.executeAsyncScript(&quot;&quot;&quot;
    var callback = arguments[arguments.length - 1];
    try {
        var lcpValue = null;
        new PerformanceObserver(function(entryList) {
            var entries = entryList.getEntries();
            if (entries.length &gt; 0) {
                lcpValue = entries[entries.length - 1].startTime;
					  
            }
        }).observe({type: &apos;largest-contentful-paint&apos;, buffered: true});

        setTimeout(function() {
            callback(lcpValue);
        }, 1000);
    } catch (e) {
        callback(null);
    }
&quot;&quot;&quot;)

def actionElapsed = System.currentTimeMillis() - actionStart
def currentUrl = WDS.browser.getCurrentUrl()
def username = WDS.vars.get(&quot;username&quot;)
def actionName = WDS.sampleResult.getSampleLabel()
def ts = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(new Date())
						 
//WDS.sampleResult.sampleEnd()
//WDS.sampleResult.setSuccessful(true)				

    // CSV logging
def filePath = org.apache.jmeter.util.JMeterUtils.getJMeterProperties().get(&quot;metricsFile&quot;)
synchronized(this) {
    def file = new File(filePath)
    file &lt;&lt; &quot;\&quot;${ts}\&quot;,\&quot;${username}\&quot;,\&quot;${actionName}\&quot;,\&quot;${currentUrl}\&quot;,\&quot;${metrics.load_ms}\&quot;,\&quot;${metrics.dom_content_loaded_ms}\&quot;,\&quot;${metrics.ttfb_ms}\&quot;,\&quot;${metrics.fcp_ms}\&quot;,\&quot;${lcp}\&quot;,\&quot;${actionElapsed}\&quot;,\&quot;true\&quot;\n&quot;
}

   WDS.log.info(&quot;Test completed successfully&quot;)     
										
} catch (Exception e) {

    WDS.log.error(&quot;ERROR OCCURRED&quot;, e)

    throw e

} finally {

    if (driver != null) {
        driver.quit()
    }
}</stringProp>
