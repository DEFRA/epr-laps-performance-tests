        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="jp@gc - WebDriver Sampler_latest_upload to excel" enabled="false">
          <stringProp name="WebDriverSampler.script">// =========================================
// JMeter WebDriver Sampler (JavaScript)
// Captures page metrics + browser info
// Writes to dynamic CSV per Test Run
// Compatible with Nashorn (no importPackage)
// =========================================

// ---- Global Run ID (unique per test execution)

import java.text.SimpleDateFormat;
import org.openqa.selenium.chrome.ChromeDriver;

if (typeof RUN_ID === &apos;undefined&apos;) {
    var SimpleDateFormat = Java.type(&quot;java.text.SimpleDateFormat&quot;);
    var Date = Java.type(&quot;java.util.Date&quot;);
    var sdf = new SimpleDateFormat(&quot;yyyyMMdd_HHmmss&quot;);
    RUN_ID = &quot;RUN_&quot; + sdf.format(new Date());
    WDS.log.info(&quot;🆔 Initialized Test Run ID: &quot; + RUN_ID);
}

// ---- Wait for page load ----
function waitForPageLoad(timeoutMs) {
    var end = java.lang.System.currentTimeMillis() + timeoutMs;
    while (java.lang.System.currentTimeMillis() &lt; end) {
        var ready = WDS.browser.executeScript(&quot;return document.readyState&quot;);
        var loaded = WDS.browser.executeScript(
            &quot;var nav = performance.getEntriesByType(&apos;navigation&apos;)[0];&quot; +
            &quot;if (nav) { return nav.loadEventEnd &gt; 0; }&quot; +
            &quot;var t = performance.timing;&quot; +
            &quot;return (t.loadEventEnd &amp;&amp; t.navigationStart) ? (t.loadEventEnd - t.navigationStart) &gt; 0 : false;&quot;
        );
        if (ready === &quot;complete&quot; &amp;&amp; loaded === true) break;
        java.lang.Thread.sleep(200);
    }
}

// ---- Write metrics to CSV ----
function writeToCSV(label, d) {
    var File = Java.type(&quot;java.io.File&quot;);
    var FileWriter = Java.type(&quot;java.io.FileWriter&quot;);
    var BufferedWriter = Java.type(&quot;java.io.BufferedWriter&quot;);
    var SimpleDateFormat = Java.type(&quot;java.text.SimpleDateFormat&quot;);
    var Date = Java.type(&quot;java.util.Date&quot;);

    //var folderPath = &quot;C:/Users/p.a.challa/OneDrive - Accenture/Desktop/DEFRA/Results&quot;;
    //var folderPath = &quot;C:/Users/gnaneshwar.vallala/OneDrive - Accenture/Documents/DEFRA/Non-Functional Testing/R 1.1 - Tests and Stats/Scripts-Result&quot;;
    var folderPath = &quot;C:/Users/gnaneshwar.vallala/OneDrive - Accenture/Documents/DEFRA\Non-Functional Testing/FSS R1.2 - Tests And Results/SIT/Test Execution/Test Results&quot;;
    var dir = new File(folderPath);
    if (!dir.exists()) {
        dir.mkdirs();
        WDS.log.info(&quot;📁 Created results folder: &quot; + folderPath);
    }

    var csvPath = folderPath + &quot;/PageMetrics_&quot; + RUN_ID + &quot;.csv&quot;;
    var csvFile = new File(csvPath);
    var append = csvFile.exists();
    var writer = new BufferedWriter(new FileWriter(csvFile, true));

    if (!append) {
        writer.write(&quot;Timestamp,TestRunID,ThreadName,Browser,Label,URL,LoadTime(ms),DOMInteractive(ms),FCP(ms)&quot;);
        writer.newLine();
    }

    var now = new SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(new Date());

    // ✅ Safe thread name retrieval
    var threadName = &quot;UnknownThread&quot;;
    try {
        if (WDS.threadContext &amp;&amp; WDS.threadContext.getThread()) {
            threadName = WDS.threadContext.getThread().getThreadName();
        } else if (WDS.threadGroup) {
            threadName = WDS.threadGroup.getName();
        }
    } catch (e) {
        WDS.log.warn(&quot;⚠️ Could not get thread name: &quot; + e);
    }

    // ✅ Browser name (Chrome, Firefox, etc.)
    var browserName = &quot;Unknown&quot;;
    try {
        browserName = WDS.browser.getCapabilities().getBrowserName();
    } catch (e) {
        WDS.log.warn(&quot;⚠️ Could not get browser name: &quot; + e);
    }

    writer.write([
        now,
        RUN_ID,
        threadName,
        browserName,
        &apos;&quot;&apos; + label + &apos;&quot;&apos;,
        &apos;&quot;&apos; + d.url + &apos;&quot;&apos;,
        d.loadTime,
        d.domInteractive,
        d.firstContentfulPaint
    ].join(&quot;,&quot;));
    writer.newLine();
    writer.close();

    WDS.log.info(&quot;✅ Metrics written to: &quot; + csvPath);
}

// ---- Capture performance metrics ----
function capturePerf(label) {
    waitForPageLoad(60000);

    var perfJson = WDS.browser.executeScript(
        &quot;var nav = performance.getEntriesByType(&apos;navigation&apos;)[0];&quot; +
        &quot;var t = performance.timing;&quot; +
        &quot;var start = (t &amp;&amp; t.navigationStart) ? t.navigationStart : performance.timeOrigin;&quot; +
        &quot;var isNavObj = !!nav;&quot; +
        &quot;var get = function(n){ return isNavObj ? nav[n] : (t ? t[n] : 0); };&quot; +
        &quot;var norm = function(v){ return (v==null || v===0) ? 0 : (isNavObj ? v : (v - start)); };&quot; +
        &quot;var fcp = performance.getEntriesByName(&apos;first-contentful-paint&apos;)[0];&quot; +
        &quot;return JSON.stringify({&quot; +
        &quot;  url: location.href,&quot; +
        &quot;  loadTime: norm(get(&apos;loadEventEnd&apos;)),&quot; +
        &quot;  domInteractive: norm(get(&apos;domInteractive&apos;)),&quot; +
        &quot;  firstContentfulPaint: fcp ? fcp.startTime : 0&quot; +
        &quot;});&quot;
    );

    var d = JSON.parse(String(perfJson));

    WDS.log.info(&quot;[&quot; + label + &quot;] url=&quot; + d.url +
                 &quot; | load=&quot; + Number(d.loadTime).toFixed(1) + &quot; ms&quot; +
                 &quot; | TTI≈domInteractive=&quot; + Number(d.domInteractive).toFixed(1) + &quot; ms&quot; +
                 &quot; | FCP=&quot; + Number(d.firstContentfulPaint).toFixed(1) + &quot; ms&quot;);

    WDS.sampleResult.setResponseMessage(&quot;[&quot; + label + &quot;] &quot; +
        &quot;url=&quot; + d.url + &quot; | load=&quot; + d.loadTime +
        &quot; | domInteractive=&quot; + d.domInteractive +
        &quot; | FCP=&quot; + d.firstContentfulPaint);

    writeToCSV(label, d);
    return d;
}

// ---------- Test Flow ----------






