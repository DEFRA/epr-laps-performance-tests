          <stringProp name="script">import org.openqa.selenium.By;
import org.openqa.selenium.WebDriver;
import org.openqa.selenium.WebElement;
import org.openqa.selenium.chrome.ChromeDriver;
import org.openqa.selenium.chrome.ChromeOptions;

import java.io.File;

public class SeleniumAutomation {

    public static void main(String[] args) {
        // Path to ChromeDriver
        System.setProperty(&quot;webdriver.chrome.driver&quot;, &quot;C:/Automation/chromedriver.exe&quot;);

        // Set download directory
        String downloadFilepath = &quot;C:/Automation/Downloads&quot;;  // Change as needed

        ChromeOptions options = new ChromeOptions();
        options.addArguments(&quot;--start-maximized&quot;);
        options.addUserProfilePreference(&quot;download.default_directory&quot;, downloadFilepath);
        options.addUserProfilePreference(&quot;download.prompt_for_download&quot;, false);
        options.addUserProfilePreference(&quot;plugins.always_open_pdf_externally&quot;, true); // To avoid Chrome&apos;s PDF viewer

        WebDriver driver = new ChromeDriver(options);

        try {
        	
            // Step 1: Navigate to the Home page page
        	 driver.get(&quot;https://eprsit.service-now.com/gsp&quot;);

        	  Thread.sleep(3000);

        	             // Step 2: Click buttons to open forms
          //  driver.findElement(By.xpath(&quot;//a[@ng-click=&quot;openLogin()&quot;]&quot;)).click();
            driver.findElement(By.xpath(&quot;//a[@ng-click=&apos;openLogin()&apos;]&quot;)).click();
            Thread.sleep(1000);  // Add delay only if needed
        	 
            // Step 1: Navigate to the login page
            driver.get(&quot;https://eprsit.service-now.com/navpage.do?sysparm_use_polaris=false&quot;);  // Change this to your actual login URL


            // Step 2: Login
            driver.findElement(By.xpath(&quot;//input[@id=&apos;username&apos;]&quot;)).sendKeys(&quot;PCHALLA_ADMIN&quot;);
            driver.findElement(By.xpath(&quot;//input[@id=&apos;password&apos;]&quot;)).sendKeys(&quot;R@m18586&quot;);
            driver.findElement(By.xpath(&quot;//button[@id=&apos;loginBtn&apos;]&quot;)).click();

            // Optional: Wait for login to complete (replace with explicit waits for reliability)
            Thread.sleep(3000);

            // Step 3: Click buttons to open forms
            driver.findElement(By.xpath(&quot;//button[@id=&apos;openForm1&apos;]&quot;)).click();
            Thread.sleep(1000);  // Add delay only if needed

            driver.findElement(By.xpath(&quot;//button[@id=&apos;openForm2&apos;]&quot;)).click();
            Thread.sleep(1000);

            driver.findElement(By.xpath(&quot;//button[@id=&apos;openForm3&apos;]&quot;)).click();
            Thread.sleep(1000);

            // Step 4: Click to download the PDF
            driver.findElement(By.xpath(&quot;//button[@id=&apos;downloadPdf&apos;]&quot;)).click();

            // Step 5: Wait and verify download
            boolean isDownloaded = waitForDownload(downloadFilepath, &quot;document.pdf&quot;, 20);  // filename as expected
            if (isDownloaded) {
                System.out.println(&quot;PDF downloaded successfully.&quot;);
            } else {
                System.out.println(&quot;PDF download failed or timed out.&quot;);
            }

        } catch (Exception e) {
            e.printStackTrace();
        } finally {
            // Close the browser
            driver.quit();
        }
    }

    // Utility to wait for file download
    public static boolean waitForDownload(String dirPath, String fileName, int timeoutSeconds) throws InterruptedException {
        File file = new File(dirPath + File.separator + fileName);
        int elapsed = 0;
        while (elapsed &lt; timeoutSeconds) {
            if (file.exists()) {
                return true;
            }
            Thread.sleep(1000);
            elapsed++;
        }
        return false;
    }
}</stringProp>
