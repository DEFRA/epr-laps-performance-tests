        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="jp@gc - WebDriver Sampler" enabled="false">
          <stringProp name="WebDriverSampler.script">// Navigate to the page
WDS.browser.get(&quot;https://eprprod.service-now.com/gsp&quot;);

// Log the page title
var title = WDS.browser.getTitle();
WDS.log.info(&quot;Page Title: &quot; + title);

// Get performance metrics from browser
var perfData = WDS.browser.executeScript(
    &quot;var timing = window.performance.timing;&quot; +
    &quot;var navEntries = window.performance.getEntriesByType(&apos;navigation&apos;);&quot; +
    &quot;var paintEntries = window.performance.getEntriesByType(&apos;paint&apos;);&quot; +

    &quot;var navigationTiming = navEntries &amp;&amp; navEntries.length &gt; 0 ? navEntries[0] : null;&quot; +
    &quot;var fcp = null;&quot; +
    &quot;for (var i = 0; i &lt; paintEntries.length; i++) {&quot; +
    &quot;  if (paintEntries[i].name === &apos;first-contentful-paint&apos;) {&quot; +
    &quot;    fcp = paintEntries[i].startTime;&quot; +
    &quot;    break;&quot; +
    &quot;  }&quot; +
    &quot;}&quot; +

    &quot;return {&quot; +
    &quot;  loadTime: timing.loadEventEnd - timing.navigationStart,&quot; +
    &quot;  domInteractive: timing.domInteractive - timing.navigationStart,&quot; +
    &quot;  firstContentfulPaint: fcp&quot; +
    &quot;};&quot;
);
// Log metrics
WDS.log.info(&quot;Page Load Time: &quot; + perfData.loadTime + &quot; ms&quot;);
WDS.log.info(&quot;Time to Interactive: &quot; + perfData.domInteractive + &quot; ms&quot;);
WDS.log.info(&quot;First Contentful Paint: &quot; + perfData.firstContentfulPaint + &quot; ms&quot;);

// Set JMeter variables
WDS.vars.put(&quot;pageLoadTime&quot;, perfData.loadTime.toString());
WDS.vars.put(&quot;domInteractive&quot;, perfData.domInteractive.toString());
WDS.vars.put(&quot;firstContentfulPaint&quot;, perfData.firstContentfulPaint.toString());</stringProp>
          <stringProp name="WebDriverSampler.parameters"></stringProp>
          <stringProp name="WebDriverSampler.language">groovy</stringProp>
        </com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler>
        <hashTree/>
        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="jp@gc - WebDriver Sampler_latest" enabled="false">
          <stringProp name="WebDriverSampler.script">// =========================================
// JMeter WebDriver Sampler (JavaScript)
// Captures load time, domInteractive (~TTI), FCP at each step
// =========================================

// Wait for full page load: readyState=complete AND loadEventEnd&gt;0
function waitForPageLoad(timeoutMs) {
    var end = java.lang.System.currentTimeMillis() + timeoutMs;
    while (java.lang.System.currentTimeMillis() &lt; end) {
        var ready = WDS.browser.executeScript(&quot;return document.readyState&quot;);
        var loaded = WDS.browser.executeScript(
            &quot;var nav = performance.getEntriesByType(&apos;navigation&apos;)[0];&quot; +
            &quot;if (nav) { return nav.loadEventEnd &gt; 0; }&quot; +
            &quot;var t = performance.timing;&quot; +
            &quot;return (t.loadEventEnd &amp;&amp; t.navigationStart) ? (t.loadEventEnd - t.navigationStart) &gt; 0 : false;&quot;
        );
        if (ready === &quot;complete&quot; &amp;&amp; loaded === true) break;
        java.lang.Thread.sleep(200);
    }
}

function capturePerf(label) {
    waitForPageLoad(60000);

    // Pull metrics as JSON string to avoid Java Map quirks
    var perfJson = WDS.browser.executeScript(
        &quot;var nav = performance.getEntriesByType(&apos;navigation&apos;)[0];&quot; +
        &quot;var t = performance.timing;&quot; +
        &quot;var start = (t &amp;&amp; t.navigationStart) ? t.navigationStart : performance.timeOrigin;&quot; +
        &quot;var isNavObj = !!nav;&quot; +
        &quot;var get = function(n){ return isNavObj ? nav[n] : (t ? t[n] : 0); };&quot; +
        &quot;var norm = function(v){ return (v==null || v===0) ? 0 : (isNavObj ? v : (v - start)); };&quot; +
        &quot;var fcp = performance.getEntriesByName(&apos;first-contentful-paint&apos;)[0];&quot; +
        &quot;return JSON.stringify({&quot; +
        &quot;  url: location.href,&quot; +
        &quot;  loadTime: norm(get(&apos;loadEventEnd&apos;)),&quot; +
        &quot;  domInteractive: norm(get(&apos;domInteractive&apos;)),&quot; +
        &quot;  domContentLoaded: norm(get(&apos;domContentLoadedEventEnd&apos;)),&quot; +
        &quot;  responseStart: norm(get(&apos;responseStart&apos;)),&quot; +
        &quot;  firstContentfulPaint: fcp ? fcp.startTime : 0&quot; +
        &quot;});&quot;
    );

    var d = JSON.parse(String(perfJson));
    // log line
    WDS.log.info(&quot;[&quot; + label + &quot;] url=&quot; + d.url +
                 &quot; | load=&quot; + Number(d.loadTime).toFixed(1) + &quot; ms&quot; +
                 &quot; | TTI≈domInteractive=&quot; + Number(d.domInteractive).toFixed(1) + &quot; ms&quot; +
                 &quot; | FCP=&quot; + Number(d.firstContentfulPaint).toFixed(1) + &quot; ms&quot;);

    // store in JMeter vars (overwrite on each step; add label prefix if you want unique vars)
    WDS.vars.put(&quot;pageLoadTime&quot;, String(d.loadTime));
    WDS.vars.put(&quot;domInteractive&quot;, String(d.domInteractive));
    WDS.vars.put(&quot;firstContentfulPaint&quot;, String(d.firstContentfulPaint));

    // put a nice summary on the sampler result
    var summary = &quot;url=&quot; + d.url +
                  &quot; | load=&quot; + Number(d.loadTime).toFixed(1) + &quot; ms&quot; +
                  &quot; | TTI≈domInteractive=&quot; + Number(d.domInteractive).toFixed(1) + &quot; ms&quot; +
                  &quot; | FCP=&quot; + Number(d.firstContentfulPaint).toFixed(1) + &quot; ms&quot;;
    WDS.sampleResult.setResponseMessage(&quot;[&quot; + label + &quot;] &quot; + summary);
    return d;
}

// ---------- Run your flow &amp; capture on each page ----------

// If you use a JMeter variable for the base URL, JMeter will substitute it here:
var P_PreProdUrl = &apos;${P_PreProdUrl}&apos;;

// 1) Login page
WDS.browser.get(P_PreProdUrl);
WDS.log.info(&quot;Page Title: &quot; + WDS.browser.getTitle());
capturePerf(&quot;Login Page&quot;);

// 2) Log in (likely a full navigation)
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;//input[@id=&apos;user_name&apos;]&quot;)).sendKeys(&quot;${username}&quot;);
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;//input[@id=&apos;user_password&apos;]&quot;)).sendKeys(&quot;${password}&quot;);
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;//button[@class=&apos;btn btn-primary&apos; and contains(text(),&apos;Log in&apos;)]&quot;)).click();
capturePerf(&quot;Post Login (Landing)&quot;);

// 3) Navigate to GSP Portal
WDS.browser.get(&quot;https://eprpreprod.service-now.com/gsp&quot;);
WDS.log.info(&quot;Page Title: &quot; + WDS.browser.getTitle());
capturePerf(&quot;GSP Portal&quot;);

// 4) Payments (may or may not be a full navigation)
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;//h3[contains(.,&apos;Payments&apos;)]&quot;)).click();
capturePerf(&quot;Payments&quot;);

// 5) View invoices
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;//a[contains(.,&apos;View invoices&apos;)]&quot;)).click();
capturePerf(&quot;Invoices&quot;);

// 6) Download first invoice (usually file download, not a navigation)
WDS.browser.findElement(org.openqa.selenium.By.xpath(&quot;(//a[contains(.,&apos;Download Invoice&apos;)])[1]&quot;)).click();
// If it opens a new page/tab and you want to measure, add another capturePerf(&quot;Download Invoice&quot;);
</stringProp>
