          <stringProp name="script">def runId = new Date().format(&quot;yyyyMMdd_HHmmss&quot;)
def env = &quot;PERF&quot;
def filePath = "scenarios\results\Test Results\${env}_UI_${runId}.csv";


props.put(&quot;metricsFile&quot;, filePath)


def file = new File(filePath)
file.parentFile.mkdirs()

if (!file.exists()) {
    file.write(&quot;Timestamp,UserID,SamplerEvent,URL,load_ms - Full Page Load Time, dom_content_loaded_ms, dom_content_loaded_ms,ttfb_ms-First Content Visible, fcp_ms, LCP - Time to Interactive (TTI),actionElapsed \n&quot;)
}


</stringProp>
        </JSR223Sampler>
