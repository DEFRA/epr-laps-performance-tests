import org.openqa.selenium.WebDriver
import org.openqa.selenium.chrome.ChromeDriver
import org.openqa.selenium.JavascriptExecutor											 
import org.openqa.selenium.By
import org.openqa.selenium.support.ui.WebDriverWait
import org.openqa.selenium.support.ui.ExpectedConditions
import java.time.Duration

WebDriver driver = null					   

try {

// Set path to your ChromeDriver
					   
								  
    System.setProperty(&quot;webdriver.chrome.driver&quot;, &quot;C:/Users/aruna.krishnamurthy/APIIntelliJ/WDIOProject/node_modules/chromedriver/lib/chromedriver/chromedriver.exe&quot;)
	 

    driver = new ChromeDriver()
    driver.manage().window().maximize()
    JavascriptExecutor js = (JavascriptExecutor) driver
// Optional log for JMeter
    WDS.log.info(&quot;:--------Groovy + Selenium is working:--------&quot;)   

// Create wait AFTER driver is initialized
    WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(10))
    
	
	def actionStart = System.currentTimeMillis()

												

// Open LAPS page
    driver.get(&quot;https://epr-laps-frontend.perf-test.cdp-int.defra.cloud/&quot;)
    //driver.get(&quot;${P_TestUrl}&quot;);
	
// Define reusable functions
def clickHome = {
    def homeLink = wait.until(
    ExpectedConditions.elementToBeClickable(
    By.xpath(&quot;//a[normalize-space()=&apos;LAPs home&apos;]&quot;)
    )
  )
    homeLink.click()
     WDS.log.info(&quot;Clicked home page link:--------&quot;)
}	
    
// Wait up to 20 seconds for the page containing &quot;List of Registered users&quot; to appear
									 
    def downloadsHeader = wait.until(
													  
    ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//table/caption[contains(normalize-space(), &apos;Registered users&apos;)]&quot;)
		 
    )
	)
    
// Log success
    WDS.log.info(&quot;Page loaded and header is visible:--------&quot; + downloadsHeader.getText())

// Select user row + click Log in --  Use hardcoded email OR JMeter variable
    String email = WDS.vars.get(&quot;email&quot;) != null ? WDS.vars.get(&quot;email&quot;) : &quot;dennis.effa.amponsah@accenture.com&quot;
    //String email = vars.get(&quot;email&quot;) != null ? vars.get(&quot;email&quot;) : sendKeys(&quot;${username}&quot;)

    def loginLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&quot;//tr[th[normalize-space()=&apos;&quot; + email + &quot;&apos;]]//a[normalize-space()=&apos;Log in&apos;]&quot;))
			
    )

    loginLink.click()
     WDS.log.info(&quot;Clicked Login link for user:-------- &quot; + email)
//select ratdio button
def radioBtn = wait.until(
  ExpectedConditions.elementToBeClickable(
  By.xpath(&quot;//label[normalize-space()=&apos;Hertfordshire County Council&apos;]&quot;)
  )
)
radioBtn.click()

 WDS.log.info(&quot;Radio selected:--------&quot;)

// Click Continue
def continueBtn = wait.until(
	ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[normalize-space()=&apos;Continue&apos;] | //a[normalize-space()=&apos;Continue&apos;]&quot;))
														   
	)
continueBtn.click()

 WDS.log.info(&quot;Clicked Continue:--------&quot;)

   
	//// Validate contents of Bank Details page  ////
			   
  def bankdetailsLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[normalize-space()=&apos;Bank details&apos;]&quot;))
					 
															 
												   
			 
		 
    )
    bankdetailsLink.click()
     WDS.log.info(&quot;Clicked Bank details link for user:--------&quot;) 

	//// Wait upto 10 seconds for the page containing title &quot;Bank Details&quot; to appear ////

									

						 
  def bankdetailsHeader = wait.until(
    ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//h1[contains(normalize-space(), &apos;Bank details&apos;)]&quot;)
														 
		 
    )
  )  
  

  // Update bank details ////

										 

							 
  def updatebankdetailsLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&apos;//*[@id=&quot;main-content&quot;]//span[contains(normalize-space(.),&quot;Change your local authority&quot;)]&apos;))
																	 
		 
    )
    updatebankdetailsLink.click()

 	def submitbankdetailsLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&apos;//*[@id=&quot;main-content&quot;]//a[contains(normalize-space(.),&quot;submit a request to update local&quot;)]&apos;))
  )
    submitbankdetailsLink.click()
     WDS.log.info(&quot;Clicked Update Bank details link for user:--------&quot;) 

// Click Continue in How it works page
def howitworksContinue = wait.until(
	ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[normalize-space()=&apos;Continue&apos;] | //a[normalize-space()=&apos;Continue&apos;]&quot;))
	)
howitworksContinue.click()
 WDS.log.info(&quot;Clicked Continue:--------&quot;)    
												 
			 
		 
	 

// Enter the new bank details

def updatePageHeader = wait.until(
  ExpectedConditions.visibilityOfElementLocated(
  By.xpath(&quot;//h1[contains(normalize-space(), &apos;Add new bank account details&apos;)]&quot;)
  )
)

// wait for and fill &quot;Name&quot;
def nameField = wait.until(
  ExpectedConditions.visibilityOfElementLocated(By.xpath(&apos;//*[@id=&quot;accountName&quot;]&apos;))
)
nameField.clear()
nameField.sendKeys(&quot;Test Name&quot;)
										 
			 
		 
	 

// wait for and fill &quot;Code&quot;
def codeField = wait.until(
  ExpectedConditions.visibilityOfElementLocated(By.xpath(&apos;//*[@id=&quot;sortCode&quot;]&apos;))
)
codeField.clear()
codeField.sendKeys(&quot;102030&quot;)

// wait for and fill &quot;Number&quot;
def numberField = wait.until(
  ExpectedConditions.visibilityOfElementLocated(By.xpath(&apos;//*[@id=&quot;accountNumber&quot;]&apos;))
)
numberField.clear()
numberField.sendKeys(&quot;98765432&quot;)

// Click Continue
def continueButton = wait.until(
	ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[normalize-space()=&apos;Continue&apos;] | //a[normalize-space()=&apos;Continue&apos;]&quot;))
					 
															 
												   
	)
continueButton.click()
 WDS.log.info(&quot;Clicked Continue:----------&quot;)

// Click Confirm and submit
def confirmButton = wait.until(
	ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[normalize-space()=&apos;Confirm and submit&apos;] | //a[normalize-space()=&apos;Confirm and submit&apos;]&quot;))
	)
confirmButton.click()
 WDS.log.info(&quot;Clicked Confirm and submit button:---------&quot;)

// Confirm bank details are submitted
def confirmbankdetailsPageHeader = wait.until(
  ExpectedConditions.visibilityOfElementLocated(
  By.xpath(&quot;//h1[contains(normalize-space(), &apos;New bank account details submitted&apos;)]&quot;)
  )
)

 WDS.log.info(&quot;Successfully updated Bank details for user:------&quot;) 
									  
													  
																			
		 
	 

// Navigate back to Bank details page //
def gotobanklink = wait.until(
	ExpectedConditions.elementToBeClickable(By.xpath(&apos;//*[@id=&quot;main-content&quot;]//a&apos;))
											  
	)
gotobanklink.click()
 WDS.log.info(&quot;Clicked go to bank link:--------&quot;)
    
// Navigate back to Home page //
clickHome()
     WDS.log.info(&quot;Clicked LAPs home page link for user:--------&quot;)    

// Validate contents of Get help page  //
								   

				
  def gethelpLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[normalize-space()=&apos;Get help and guidance&apos;]&quot;))
									  
		 
    )
  gethelpLink.click()
   WDS.log.info(&quot;Clicked Get help link for user:--------&quot;) 

	// Wait upto 10 seconds for the page containing title &quot;Get help&quot; to appear //
					   

				  
  def gethelpheader = wait.until(
    ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//h1[contains(normalize-space(),&apos;Get help and guidance&apos;)]&quot;)
									 
		 
    )
  )      
	
  // Navigate back to LAPs Home page //
	clickHome()
     WDS.log.info(&quot;Clicked LAPs home page link for user:--------&quot;)    
	// Validate contents of Payment page //
  def paymentLink = wait.until(
    ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[normalize-space()=&apos;Payment documents&apos;]&quot;))
		 
    )
  paymentLink.click()
   WDS.log.info(&quot;Clicked Payment documents link for user:--------&quot;)    

////////PENDING::: ///////////need to write the code from connecting to test env for the  payment docs section ///////////////////////////
// Wait upto 10 seconds for the page containing title &quot;Payment documents&quot; to appear //
						 
  def paymentDocumentheader = wait.until(
    ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//h1[contains(normalize-space(),&apos;Payment documents&apos;)]&quot;)
   )
  ) 

// Navigate back to LAPs Home page //
clickHome()
 WDS.log.info(&quot;Clicked LAPs home page link for user:--------&quot;)    
        
// Allow paint entries to settle a little
Thread.sleep(1500)

// Collect navigation + paint metrics
def metrics = WDS.browser.executeScript(&quot;&quot;&quot;
    var result = {
        load_ms: null,
        dom_content_loaded_ms: null,
        ttfb_ms: null,
        fcp_ms: null,
            paint_count: 0
    };

    var nav = performance.getEntriesByType(&apos;navigation&apos;);
    if (nav &amp;&amp; nav.length &gt; 0) {
        var n = nav[0];
        result.load_ms = n.loadEventEnd;
        result.dom_content_loaded_ms = n.domContentLoadedEventEnd;
        result.ttfb_ms = n.responseStart - n.requestStart;
    } else if (performance.timing) {
        result.load_ms = performance.timing.loadEventEnd - performance.timing.navigationStart;
        result.dom_content_loaded_ms = performance.timing.domContentLoadedEventEnd - performance.timing.navigationStart;
        result.ttfb_ms = performance.timing.responseStart - performance.timing.requestStart;
    }

    var paints = performance.getEntriesByType(&apos;paint&apos;);
    for (var i = 0; i &lt; paints.length; i++) {
        if (paints[i].name === &apos;first-contentful-paint&apos;) {
			   
            result.fcp_ms = paints[i].startTime;
            break;
															  
        }
    }

    return result;
&quot;&quot;&quot;)

// Capture LCP separately
def lcp = WDS.browser.executeAsyncScript(&quot;&quot;&quot;
    var callback = arguments[arguments.length - 1];
    try {
        var lcpValue = null;
        new PerformanceObserver(function(entryList) {
            var entries = entryList.getEntries();
            if (entries.length &gt; 0) {
                lcpValue = entries[entries.length - 1].startTime;
					  
            }
        }).observe({type: &apos;largest-contentful-paint&apos;, buffered: true});

        setTimeout(function() {
            callback(lcpValue);
        }, 1000);
    } catch (e) {
        callback(null);
    }
&quot;&quot;&quot;)

def actionElapsed = System.currentTimeMillis() - actionStart
def currentUrl = WDS.browser.getCurrentUrl()
def username = WDS.vars.get(&quot;username&quot;)
def actionName = WDS.sampleResult.getSampleLabel()
def ts = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(new Date())
						 
//WDS.sampleResult.sampleEnd()
//WDS.sampleResult.setSuccessful(true)				

    // CSV logging
def filePath = org.apache.jmeter.util.JMeterUtils.getJMeterProperties().get(&quot;metricsFile&quot;)
synchronized(this) {
    def file = new File(filePath)
    file &lt;&lt; &quot;\&quot;${ts}\&quot;,\&quot;${username}\&quot;,\&quot;${actionName}\&quot;,\&quot;${currentUrl}\&quot;,\&quot;${metrics.load_ms}\&quot;,\&quot;${metrics.dom_content_loaded_ms}\&quot;,\&quot;${metrics.ttfb_ms}\&quot;,\&quot;${metrics.fcp_ms}\&quot;,\&quot;${lcp}\&quot;,\&quot;${actionElapsed}\&quot;,\&quot;true\&quot;\n&quot;
}

   WDS.log.info(&quot;Test completed successfully&quot;)     
										
} catch (Exception e) {

    WDS.log.error(&quot;ERROR OCCURRED&quot;, e)

    throw e

} finally {

    if (driver != null) {
        driver.quit()
    }
}</stringProp>
