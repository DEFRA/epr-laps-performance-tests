        <com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler guiclass="com.googlecode.jmeter.plugins.webdriver.sampler.gui.WebDriverSamplerGui" testclass="com.googlecode.jmeter.plugins.webdriver.sampler.WebDriverSampler" testname="01 - jp@gc - WebDriver Sampler - Login And Portal Home">
          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.JavascriptExecutor
import org.openqa.selenium.By
import org.openqa.selenium.support.ui.WebDriverWait
import org.openqa.selenium.support.ui.ExpectedConditions
import java.time.Duration

def driver = WDS.browser
driver.manage().window().maximize()

JavascriptExecutor js = (JavascriptExecutor) driver
WDS.log.info(&quot;:--------START OF LOGIN SCRIPT:--------&quot;)

    // Create explicit wait
    WebDriverWait wait = new WebDriverWait(driver, Duration.ofSeconds(20))


// Open LAPS page
    driver.get(&quot;https://epr-laps-frontend.dev.cdp-int.defra.cloud/&quot;)
// Wait until browser leaves temporary data: page
    wait.until { drv -&gt;
        !drv.getCurrentUrl().startsWith(&quot;data:&quot;)
    }

    WDS.log.info(&quot;Current URL after navigation: &quot; + driver.getCurrentUrl())
	
// Define reusable functions
def clickHome = {
    def homeLink = wait.until(
    ExpectedConditions.elementToBeClickable(
    By.xpath(&quot;//a[normalize-space()=&apos;LAPs home&apos;]&quot;)
    )
  )
    homeLink.click()
     WDS.log.info(&quot;Clicked home page link:--------&quot;)
}	
// Wait up to 20 seconds for the page containing &quot;List of Registered users&quot; 
to appear
									 
    def downloadsHeader = 
wait.until(ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//table
/caption[contains(normalize-space(), &apos;Registered users&apos;)]&quot;)))
    
// Log success
    WDS.log.info(&quot;Page loaded and header is visible:--------&quot; + 
downloadsHeader.getText())

// Select user row + click Log in --  Use hardcoded email OR JMeter variable
    String email = WDS.vars.get(&quot;email&quot;)

    // String email = WDS.vars.get(&quot;email&quot;) != null ? WDS.vars.get(&quot;email&quot;) : 
&quot;tester8@example.com&quot;

    def loginLink = wait.until(
    
ExpectedConditions.elementToBeClickable(By.xpath(&quot;//tr[th[normalize-space(
)=&apos;&quot; + email + &quot;&apos;]]//a[normalize-space()=&apos;Log in&apos;]&quot;)))

    def actionStart = System.currentTimeMillis()
        
    loginLink.click()
     WDS.log.info(&quot;Clicked Login link for user:-------- &quot; + email)
//select ratdio button
def radioBtn = wait.until(
  ExpectedConditions.elementToBeClickable(
  By.xpath(&quot;//label[normalize-space()=&apos;North Tyneside Council&apos;]&quot;)
  )
)
radioBtn.click()
WDS.log.info(&quot;Radio selected:--------&quot;)
// Click Continue
def continueBtn = wait.until(
	
ExpectedConditions.elementToBeClickable(By.xpath(&quot;//button[normalize-space
()=&apos;Continue&apos;] | //a[normalize-space()=&apos;Continue&apos;]&quot;)))
continueBtn.click()
 WDS.log.info(&quot;Clicked Continue and landed in LAPS Home page&quot;)
    WDS.log.info(&quot;:--------END OF LOGIN SCRIPT:--------&quot;)   
// Allow paint entries to settle a little
Thread.sleep(1500)

/////////////////////////
// PERFORMANCE METRICS
/////////////////////////

def metrics = WDS.browser.executeScript(&quot;&quot;&quot;
    var result = {
        load_ms: null,
        dom_content_loaded_ms: null,
        ttfb_ms: null,
        fcp_ms: null
    };

    var nav = performance.getEntriesByType(&apos;navigation&apos;);
    if (nav &amp;&amp; nav.length &gt; 0) {
        var n = nav[0];
        result.load_ms = n.loadEventEnd;
        result.dom_content_loaded_ms = n.domContentLoadedEventEnd;
        result.ttfb_ms = n.responseStart - n.requestStart;
    } else if (performance.timing) {
        result.load_ms = performance.timing.loadEventEnd - 
performance.timing.navigationStart;
        result.dom_content_loaded_ms = 
performance.timing.domContentLoadedEventEnd - 
performance.timing.navigationStart;
        result.ttfb_ms = performance.timing.responseStart - 
performance.timing.requestStart;
    }

    var paints = performance.getEntriesByType(&apos;paint&apos;);
    for (var i = 0; i &lt; paints.length; i++) {
        if (paints[i].name === &apos;first-contentful-paint&apos;) {
            result.fcp_ms = paints[i].startTime;
            break;
        }
    }

    return result;
&quot;&quot;&quot;)

// LCP
def lcp = WDS.browser.executeAsyncScript(&quot;&quot;&quot;
    var callback = arguments[arguments.length - 1];

    var lcpValue = null;

    try {
        new PerformanceObserver(function(list) {
            var entries = list.getEntries();
            if (entries.length &gt; 0) {
                lcpValue = entries[entries.length - 1].startTime;
            }
        }).observe({type: &apos;largest-contentful-paint&apos;, buffered: true});

        setTimeout(function() {
            callback(lcpValue);
        }, 1000);

    } catch (e) {
        callback(null);
    }
&quot;&quot;&quot;)


def actionElapsed = System.currentTimeMillis() - actionStart
def currentUrl = WDS.browser.getCurrentUrl()
def actionName = WDS.sampleResult.getSampleLabel()
						 
//WDS.sampleResult.sampleEnd()
//WDS.sampleResult.setSuccessful(true)				

    // CSV logging

def ts = new java.text.SimpleDateFormat(&quot;yyyy-MM-dd HH:mm:ss&quot;).format(new 
Date())

def filePath = 
org.apache.jmeter.util.JMeterUtils.getJMeterProperties().get(&quot;metricsFile&quot;)
synchronized(this) {
    def file = new File(filePath)
    file &lt;&lt; 
&quot;\&quot;${ts}\&quot;,\&quot;${actionName}\&quot;,\&quot;${currentUrl}\&quot;,\&quot;${metrics.load_ms}\&quot;,\&quot;${
metrics.dom_content_loaded_ms}\&quot;,\&quot;${metrics.ttfb_ms}\&quot;,\&quot;${metrics.fcp_ms
}\&quot;,\&quot;${lcp}\&quot;,\&quot;${actionElapsed}\&quot;,\&quot;true\&quot;\n&quot;
}

//def ts = new Date().format(&quot;yyyy-MM-dd HH:mm:ss&quot;)

//if (!file.exists()) {
//    file &lt;&lt; 
&quot;step,timestamp,username,load,dom,ttfb,fcp,lcp,elapsed,success\n&quot;
//}

//def actionElapsed = System.currentTimeMillis() - actionStart

//file &lt;&lt; 
&quot;login,${ts},${email},${metrics.load_ms},${metrics.dom_content_loaded_ms},${me
trics.ttfb_ms},${metrics.fcp_ms},${lcp},${actionElapsed},true\n&quot;</stringProp>
