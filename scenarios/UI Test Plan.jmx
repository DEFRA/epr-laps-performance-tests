          <stringProp name="WebDriverSampler.script">import org.openqa.selenium.By
import org.openqa.selenium.JavascriptExecutor
import org.openqa.selenium.support.ui.WebDriverWait
import org.openqa.selenium.support.ui.ExpectedConditions
import java.time.Duration

def driver = WDS.browser
def js = (JavascriptExecutor) driver

WDS.log.info(&quot;:--------START OF DOCUMENT SCRIPT:--------&quot;)

def wait = new WebDriverWait(driver, Duration.ofSeconds(30))

// Ensure real app page
wait.until { drv -&gt;
    !drv.getCurrentUrl().startsWith(&quot;data:&quot;)
}

WDS.log.info(&quot;Continuing session&quot;)
WDS.log.info(&quot;Current URL: &quot; + driver.getCurrentUrl())

// Wait DOM ready
wait.until {
    js.executeScript(&quot;return document.readyState&quot;) == &quot;complete&quot;
}

// FIXED XPath

  def gethelpLink = wait.until(
    
ExpectedConditions.elementToBeClickable(By.xpath(&quot;//a[normalize-space()=&apos;G
et help and guidance&apos;]&quot;)))

  def actionStart = System.currentTimeMillis()
  WDS.log.info(&quot;Start time: &quot; + actionStart.getText())

  gethelpLink.click()
   WDS.log.info(&quot;Clicked Get help and guidance link for user:--------&quot;)    
						 

// FIXED XPath
  def Gethelpandguidancetheader = wait.until(
    
ExpectedConditions.visibilityOfElementLocated(By.xpath(&quot;//h1[contains(norm
alize-space(),&apos;Get help and guidance&apos;)]&quot;)))

WDS.log.info(&quot;Get Help Page loaded: &quot; + Gethelpandguidancetheader.getText())


Thread.sleep(1500)

// Collect navigation + paint metrics
def metrics = WDS.browser.executeScript(&quot;&quot;&quot;
    var result = {
        load_ms: null,
        dom_content_loaded_ms: null,
        ttfb_ms: null,
        fcp_ms: null
    };

    var nav = performance.getEntriesByType(&apos;navigation&apos;);
    if (nav &amp;&amp; nav.length &gt; 0) {
        var n = nav[0];
        result.load_ms = n.loadEventEnd;
        result.dom_content_loaded_ms = n.domContentLoadedEventEnd;
        result.ttfb_ms = n.responseStart - n.requestStart;
    } else if (performance.timing) {
        result.load_ms = performance.timing.loadEventEnd - 
performance.timing.navigationStart;
        result.dom_content_loaded_ms = 
performance.timing.domContentLoadedEventEnd - 
performance.timing.navigationStart;
        result.ttfb_ms = performance.timing.responseStart - 
performance.timing.requestStart;
    }

    var paints = performance.getEntriesByType(&apos;paint&apos;);
    for (var i = 0; i &lt; paints.length; i++) {
        if (paints[i].name === &apos;first-contentful-paint&apos;) {
            result.fcp_ms = paints[i].startTime;
            break;
        }
    }

    return result;
&quot;&quot;&quot;)

// Capture LCP separately
def lcp = WDS.browser.executeAsyncScript(&quot;&quot;&quot;
    var callback = arguments[arguments.length - 1];
    try {
        var lcpValue = null;
        new PerformanceObserver(function(entryList) {
            var entries = entryList.getEntries();
            if (entries.length &gt; 0) {
                lcpValue = entries[entries.length - 1].startTime;
            }
        }).observe({type: &apos;largest-contentful-paint&apos;, buffered: true});

        setTimeout(function() {
            callback(lcpValue);
        }, 1000);
    } catch (e) {
        callback(null);
    }
&quot;&quot;&quot;)

