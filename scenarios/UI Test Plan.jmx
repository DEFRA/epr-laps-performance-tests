        By.xpath(&quot;//a[normalize-space()=&apos;Payment documents&apos;]&quot;)
    )
)

def actionStart = System.currentTimeMillis()

documentsLink.click()

WDS.log.info(&quot;Clicked documents link&quot;)

// FIXED XPath
def documentsHeader = wait.until(
    ExpectedConditions.visibilityOfElementLocated(
        By.xpath(&quot;//h1[contains(normalize-space(),&apos;Payment documents&apos;)]&quot;)
    )
)

WDS.log.info(&quot;Documents page loaded: &quot; + documentsHeader.getText())


Thread.sleep(1500)

// Collect navigation + paint metrics
def metrics = WDS.browser.executeScript(&quot;&quot;&quot;
    var result = {
        load_ms: null,
        dom_content_loaded_ms: null,
        ttfb_ms: null,
        fcp_ms: null
