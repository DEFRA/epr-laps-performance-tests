          <stringProp name="script">def runId = new Date().format(&quot;yyyyMMdd_HHmmss&quot;)
def env = &quot;PERF&quot;
def baseDir = System.getProperty(&quot;baseDir&quot;, &quot;C:/TestResults&quot;)

def filePath = &quot;${baseDir}/${env}_UI_${runId}.csv&quot;
props.put(&quot;metricsFile&quot;, filePath)


def file = new File(filePath)
file.parentFile.mkdirs()

if (!file.exists()) {
    file.write(&quot;Timestamp,SamplerEvent,URL,load_ms - Full Page Load Time, dom_content_loaded_ms,ttfb_ms-First Content Visible, fcp_ms, LCP - Time to Interactive (TTI),actionElapsed \n&quot;)
}


</stringProp>
        </JSR223Sampler>
