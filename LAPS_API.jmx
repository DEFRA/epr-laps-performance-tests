          <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
            <stringProp name="scriptLanguage">groovy</stringProp>
            <stringProp name="parameters"></stringProp>
            <stringProp name="filename"></stringProp>
            <stringProp name="cacheKey">true</stringProp>
            <stringProp name="script">import groovy.json.JsonSlurper

log.info(&quot;===== JSR223 ASSERTION START =====&quot;)

def responseBody = prev.getResponseDataAsString()

log.info(&quot;Raw Response Body: &quot; + responseBody)
log.info(&quot;Response Length: &quot; + (responseBody != null ? responseBody.length() : &quot;null&quot;))

if (responseBody == null || responseBody.trim().isEmpty()) {
    AssertionResult.setFailure(true)
    AssertionResult.setFailureMessage(&quot;Response body is empty&quot;)
    log.error(&quot;Assertion Failed: Response body is empty&quot;)
} else {
    log.info(&quot;Assertion Passed: Response body is not empty&quot;)
}

log.info(&quot;===== JSR223 ASSERTION END =====&quot;)</stringProp>
          </JSR223PostProcessor>
